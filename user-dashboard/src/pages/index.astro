---
import UserLayout from '../layouts/UserLayout.astro';
import UserHeader from '../components/UserHeader.jsx';
import FormContainer from '../components/FormContainer.jsx';
import '../styles/global.css';
---

<UserLayout>
  <div class="min-h-screen flex flex-col selection:bg-indigo-100 selection:text-indigo-900">
    <UserHeader client:load />
    
    <main class="flex-1 py-8 md:py-16 px-4 md:px-8">
      <div class="max-w-7xl mx-auto">
        <FormContainer client:load />
      </div>
    </main>
    
    <footer class="py-10 text-center border-t border-slate-100 bg-white/50 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] leading-relaxed">
          © 2026 Ateneo de Zamboanga University<br class="sm:hidden" />
          <span class="hidden sm:inline mx-4 text-slate-200">|</span>
          University Communications Office
        </p>
      </div>
    </footer>
  </div>
</UserLayout>
