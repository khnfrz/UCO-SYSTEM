---
<header class="flex items-center justify-between p-6 bg-white border-b border-gray-100 sticky top-0 z-10 font-sans">
  <div class="flex items-center gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-600 font-serif uppercase tracking-widest">University Communications Office</h1>
      <p class="text-xs font-medium text-slate-400 tracking-wider uppercase mt-0.5">MRTS: Media Request Tracking System</p>
    </div>
  </div>
  
  <div class="flex items-center gap-6">
    <div class="relative group">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 group-focus-within:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input 
        type="search" 
        placeholder="Search requests..." 
        class="pl-10 pr-4 py-2 w-80 bg-white border border-slate-200 rounded-lg text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400 transition-all shadow-sm" 
      />
    </div>
  </div>
</header>