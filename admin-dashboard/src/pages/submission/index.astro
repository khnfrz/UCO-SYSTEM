---
import Layout from '../../layouts/Layout.astro';
import ResponsiveLayout from '../../components/layout/ResponsiveLayout.jsx';
import SubmissionDetailContent from '../../components/SubmissionDetailContent.jsx';
import '../../styles/global.css';
---

<Layout title="Submission Details | UCO Admin">
  <ResponsiveLayout client:load>
    <div class="mb-8">
      <a href="/submissions" class="text-[10px] font-black text-[#A3AED0] hover:text-[#547DBE] uppercase tracking-widest flex items-center gap-2 transition-colors">
        ← BACK TO SUBMISSIONS
      </a>
    </div>
    
    <div class="mb-8">
        <h1 class="text-3xl font-black text-[#1B2559] uppercase tracking-wider">OFFICE OF THE PRESIDENT</h1>
    </div>

    <SubmissionDetailContent client:load />
  </ResponsiveLayout>
</Layout>
